let correct=0,answered=0;
function buildQuiz(){
  correct=0;answered=0;
  document.getElementById('scoreChip').textContent='0 / 15';
  document.getElementById('progBar').style.width='0%';
  document.getElementById('finalBox').classList.remove('show');
  const body=document.getElementById('quizBody');body.innerHTML='';
  QS.forEach((q,qi)=>{
    const card=document.createElement('div');card.className='qcard';card.id='qcard'+qi;
    card.innerHTML=`
      <div class="qnum">QUESTION ${qi+1} OF ${QS.length}</div>
      <div class="qtext">${q.q}</div>
      <div class="opts" id="opts${qi}">
        ${q.opts.map((o,oi)=>`<button class="opt" onclick="answer(${qi},${oi})">${String.fromCharCode(65+oi)}. ${o}</button>`).join('')}
      </div>
      <div class="feedback" id="fb${qi}"></div>`;
    body.appendChild(card);
  });
}
function answer(qi,chosen){
  const q=QS[qi];const card=document.getElementById('qcard'+qi);
  const btns=document.querySelectorAll(`#opts${qi} .opt`);
  btns.forEach(b=>b.disabled=true);
  const ok=chosen===q.ans;
  btns[chosen].classList.add(ok?'correct':'wrong');
  if(!ok)btns[q.ans].classList.add('correct');
  const fb=document.getElementById('fb'+qi);
  fb.textContent=(ok?'✅ Correct! ':'❌ Not quite! ')+q.explain;
  fb.className='feedback '+(ok?'ok':'bad');
  card.classList.add(ok?'ok':'bad');
  if(ok)correct++;answered++;
  document.getElementById('scoreChip').textContent=`${correct} / ${answered}`;
  document.getElementById('progBar').style.width=`${(answered/QS.length)*100}%`;
  if(answered===QS.length)showFinal();
}
function showFinal(){
  const fb=document.getElementById('finalBox');
  const fs=document.getElementById('finalScore');
  const fst=document.getElementById('finalStars');
  const fm=document.getElementById('finalMsg');
  fs.textContent=`${correct} / ${QS.length}`;
  if(correct===QS.length){fs.className='final-score perfect';fst.textContent='⭐⭐⭐';fm.textContent='PERFECT SCORE!\nStatistics Pro in the Making!\nYou crushed it! 📊';}
  else if(correct>=12){fs.className='final-score great';fst.textContent='⭐⭐';fm.textContent='EXCELLENT WORK!\nYou understand statistics well!\nReady for data visualization!';}
  else{fs.className='final-score okish';fst.textContent='⭐';fm.textContent='GOOD START!\nReview the concepts and\ntry the interactives again!';}
  fb.classList.add('show');
}
buildQuiz();
</script>
